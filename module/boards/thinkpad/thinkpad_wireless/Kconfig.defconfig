#
# Kconfig.defconfig: Hardware-level defaults for the thinkpad_wireless board.
# User preferences (keyboard name, sleep timeouts, etc.) go in
# config/thinkpad_wireless.conf instead.

if BOARD_THINKPAD_WIRELESS

# nRF52840 hardware requires these for proper operation
config BT_DEVICE_NAME_MAX
    default 32

endif # BOARD_THINKPAD_WIRELESS
