# thinkpad_wireless_defconfig: Hardware-level Kconfig for the thinkpad_wireless board.
# This file sets hardware-specific options that are always required for this board.
# User preferences (BLE name, sleep timeouts, features) are in config/thinkpad_wireless.conf.

# Enable ADC for battery voltage measurement (hardware requirement)
CONFIG_ADC=y

# Enable PWM for breathing power LED (hardware requirement)
CONFIG_PWM=y

# PS/2 & Bluetooth Controller Tuning for TrackPoint coexistence
CONFIG_PM_DEVICE=y
CONFIG_BT_CTLR_ADVANCED_FEATURES=y
CONFIG_BT_CTLR_LLL_PRIO=1
CONFIG_BT_CTLR_ULL_HIGH_PRIO=2
CONFIG_BT_CTLR_ULL_LOW_PRIO=2
