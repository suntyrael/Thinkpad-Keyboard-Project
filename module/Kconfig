# PS/2 TrackPoint driver module Kconfig
# Extracted from the thinkpad_wireless board to allow reuse across boards.

# Compatible definitions for Kconfig preprocessor to avoid comma argument splitting
DT_COMPAT_ZMK_INPUT_MOUSE_PS2 := zmk,input-mouse-ps2
DT_COMPAT_ZMK_INPUT_LISTENER_PS2 := zmk,input-listener-ps2
DT_COMPAT_ZMK_BEHAVIOR_MOUSE_SETTING := zmk,behavior-mouse-setting
DT_COMPAT_PS2_GPIO := gpio-ps2
DT_COMPAT_PS2_UART := uart-ps2

# TrackPoint PS/2 Driver Configurations
config ZMK_INPUT_MOUSE_PS2
    bool "Enable ZMK PS/2 Mouse/TrackPoint driver"
    depends on (!ZMK_SPLIT || ZMK_SPLIT_ROLE_CENTRAL)
    select ZMK_POINTING
    select ZMK_POINTING_SMOOTH_SCROLLING
    select PS2
    default y if $(dt_compat_enabled,$(DT_COMPAT_ZMK_INPUT_MOUSE_PS2))

config ZMK_INPUT_LISTENER_PS2
    bool "Enable PS/2 mouse input listener"
    default y if $(dt_compat_enabled,$(DT_COMPAT_ZMK_INPUT_LISTENER_PS2))

config ZMK_BEHAVIOR_MOUSE_SETTING
    bool "Enable mouse setting behaviors"
    default y if ZMK_INPUT_MOUSE_PS2 && $(dt_compat_enabled,$(DT_COMPAT_ZMK_BEHAVIOR_MOUSE_SETTING))

config PS2_GPIO
    bool "GPIO bit banging PS/2 support"
    default y if $(dt_compat_enabled,$(DT_COMPAT_PS2_GPIO))

config PS2_UART
    bool "GPIO bit banging PS/2 support through UART"
    default y if $(dt_compat_enabled,$(DT_COMPAT_PS2_UART))
    select SERIAL
    select UART_ASYNC_API
    select UART_USE_RUNTIME_CONFIGURE
