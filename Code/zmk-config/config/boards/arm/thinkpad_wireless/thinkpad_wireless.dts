/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>

/ {
    model = "Thinkpad Wireless";
    compatible = "thinkpad,wireless";

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,code-partition = &slot0_partition;
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
        zmk,battery = &vbatt;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <8>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14) RC(3,15)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11) RC(4,12) RC(4,13) RC(4,14) RC(4,15)
            RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,5) RC(5,6) RC(5,7) RC(5,8) RC(5,9) RC(5,10) RC(5,11) RC(5,12) RC(5,13) RC(5,14) RC(5,15)
            RC(6,0) RC(6,1) RC(6,2) RC(6,3) RC(6,4) RC(6,5) RC(6,6) RC(6,7) RC(6,8) RC(6,9) RC(6,10) RC(6,11) RC(6,12) RC(6,13) RC(6,14) RC(6,15)
            RC(7,0) RC(7,1) RC(7,2) RC(7,3) RC(7,4) RC(7,5) RC(7,6) RC(7,7) RC(7,8) RC(7,9) RC(7,10) RC(7,11) RC(7,12) RC(7,13) RC(7,14) RC(7,15)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row"; /* TODO: Verify Diode Direction */

        row-gpios
            = <&gpio0 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE0 AC9 -> P0.14 */
            , <&gpio0 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE1 AC15 -> TODO */
            , <&gpio0 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE2 AC11 -> TODO */
            , <&gpio0 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE3 AD10 -> TODO */
            , <&gpio0 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE4 AD12 -> TODO */
            , <&gpio0 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE5 AD8  -> TODO */
            , <&gpio0 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE6 AC17 -> TODO */
            , <&gpio0 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE7 AD16 -> TODO */
            ;

        col-gpios
            = <&gpio1 10 GPIO_ACTIVE_HIGH> /* DRV0 A20 -> P1.10 */
            , <&gpio1 8  GPIO_ACTIVE_HIGH> /* DRV1 P2  -> P1.08 */
            , <&gpio1 6  GPIO_ACTIVE_HIGH> /* DRV2 R24 -> P1.06 */
            , <&gpio1 4  GPIO_ACTIVE_HIGH> /* DRV3 U24 -> P1.04 */
            , <&gpio1 0  GPIO_ACTIVE_HIGH> /* DRV4 AD22 -> P1.00 */
            , <&gpio1 1  GPIO_ACTIVE_HIGH> /* DRV5 Y23 -> P1.01 */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV6 V23 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV7 T23 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV8 W24 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV9 R1  -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV10 P23 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV11 B19 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV12 A16 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV13 A14 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV14 B17 -> TODO */
            , <&gpio0 0  GPIO_ACTIVE_HIGH> /* DRV15 B15 -> TODO */
            ;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-voltage-divider";
        io-channels = <&adc 0>; /* TODO: Map U4.A12 to correct SAADC channel */
        output-ohms = <2000000>;
        full-ohms = <(2000000 + 806000)>; /* Adjust based on your schematic voltage divider R20/R21 */
    };
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        sd_partition: partition@0 {
            label = "softdevice";
            reg = <0x00000000 0x00026000>;
        };
        code_partition: partition@26000 {
            label = "code_partition";
            reg = <0x00026000 0x000c6000>;
        };
        storage_partition: partition@ec000 {
            label = "storage";
            reg = <0x000ec000 0x00008000>;
        };
        boot_partition: partition@f4000 {
            label = "adafruit_boot";
            reg = <0x000f4000 0x0000c000>;
        };
    };
};

&gpio0 {
    status = "okay";
};

&gpio1 {
    status = "okay";
};
