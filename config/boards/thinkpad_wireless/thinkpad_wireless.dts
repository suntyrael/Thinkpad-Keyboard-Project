/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <dt-bindings/zmk/hid_indicators.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/pinctrl/nrf-pinctrl.h>

/ {
    model = "Thinkpad Wireless";
    compatible = "thinkpad,wireless";

    aliases {
        pwm-led0 = &pwm_led_power;
    };

    indicators {
        compatible = "zmk,indicator-leds";
        caps_lock_indicator: caps_lock_indicator {
            indicator = <HID_INDICATOR_CAPS_LOCK>;
            leds = <&caps_lock_led>;
        };
    };

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,code-partition = &code_partition;
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
        zmk,battery = &vbatt;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <9>;
        map = <
            /* Row 0: F-row + Esc */
            RC(5,0)  RC(0,1)  RC(0,2)  RC(3,2)  RC(5,2)  RC(5,8)  RC(5,5)  RC(3,6)  RC(0,6)  RC(0,8)  RC(1,8)  RC(1,10) RC(1,9)  RC(0,12) RC(1,12) RC(0,10)
            /* Row 1: Number row */
            RC(0,0)  RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(0,3)  RC(0,4)  RC(1,4)  RC(1,5)  RC(1,6)  RC(1,7)  RC(0,7)  RC(0,5)  RC(3,8)  RC(3,11) RC(3,12)
            /* Row 2: Tab row */
            RC(3,0)  RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(3,3)  RC(3,4)  RC(2,4)  RC(2,5)  RC(2,6)  RC(2,7)  RC(3,7)  RC(3,5)  RC(4,8)  RC(4,11) RC(4,12)
            /* Row 3: Caps row */
            RC(3,1)  RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(5,3)  RC(5,4)  RC(4,4)  RC(4,5)  RC(4,6)  RC(4,7)  RC(5,7)  RC(6,8)  RC(5,11) RC(5,14) RC(5,15)
            /* Row 4: Shift row */
            RC(3,14) RC(6,0)  RC(6,1)  RC(6,2)  RC(6,3)  RC(7,3)  RC(7,4)  RC(6,4)  RC(6,5)  RC(6,6)  RC(7,7)  RC(6,14) RC(5,12) RC(6,13) RC(0,13) RC(0,14)
            /* Row 5: Ctrl/Space row */
            RC(0,15) RC(3,9)  RC(5,13) RC(4,13) RC(4,14) RC(7,8)  RC(5,15) RC(7,14) RC(7,13) RC(6,15) RC(7,12) RC(7,10) RC(7,9)  RC(1,13) RC(1,14) RC(2,14)
            /* Row 6: Media keys */
            RC(2,10) RC(3,10) RC(4,10) RC(6,10) RC(5,10) RC(0,11) RC(1,11) RC(6,11) RC(7,11) RC(1,13) RC(2,13) RC(6,12) RC(7,15) RC(2,15) RC(3,15) RC(4,15)
            /* Row 7: Unused */
            RC(0,9)  RC(1,15) RC(2,9)  RC(3,13) RC(4,9)  RC(5,9)  RC(6,9)  RC(7,5)  RC(7,6)  RC(0,13) RC(0,14) RC(0,15) RC(1,13) RC(1,14) RC(2,13) RC(2,14)
            /* Row 8: Direct keys */
            RC(8,0)  RC(8,1)
        >;
    };

    kscan0: kscan_composite {
        compatible = "zmk,kscan-composite";
        rows = <9>;
        columns = <16>;
        wakeup-source;

        matrix {
            kscan = <&matrix_kscan>;
        };

        direct {
            kscan = <&direct_kscan>;
            row-offset = <8>;
            column-offset = <0>;
        };
    };

    matrix_kscan: kscan_matrix {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        row-gpios
            = <&gpio0 26 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE0 G1 -> P0.26 */
            , <&gpio0 28 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE1 B11 -> P0.28 */
            , <&gpio0 5  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE2 K2 -> P0.05 */
            , <&gpio0 4  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE3 J1 -> P0.04 */
            , <&gpio0 27 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE4 H2 -> P0.27 */
            , <&gpio0 7  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE5 M2 -> P0.07 */
            , <&gpio1 12 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE6 B17 -> P1.12 */
            , <&gpio1 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* SENSE7 B15 -> P1.14 */
            ;

        col-gpios
            = <&gpio0 13 GPIO_ACTIVE_HIGH> /* DRV0 AD8 -> P0.13 */
            , <&gpio0 20 GPIO_ACTIVE_HIGH> /* DRV1 AD16 -> P0.20 */
            , <&gpio0 22 GPIO_ACTIVE_HIGH> /* DRV2 AD18 -> P0.22 */
            , <&gpio0 24 GPIO_ACTIVE_HIGH> /* DRV3 AD20 -> P0.24 */
            , <&gpio1 1  GPIO_ACTIVE_HIGH> /* DRV4 Y23 -> P1.01 */
            , <&gpio0 25 GPIO_ACTIVE_HIGH> /* DRV5 AC21 -> P0.25 */
            , <&gpio1 0  GPIO_ACTIVE_HIGH> /* DRV6 AD22 -> P1.00 */
            , <&gpio0 21 GPIO_ACTIVE_HIGH> /* DRV7 AC17 -> P0.21 */
            , <&gpio0 23 GPIO_ACTIVE_HIGH> /* DRV8 AC19 -> P0.23 */
            , <&gpio0 16 GPIO_ACTIVE_HIGH> /* DRV9 AC11 -> P0.16 */
            , <&gpio0 19 GPIO_ACTIVE_HIGH> /* DRV10 AC15 -> P0.19 */
            , <&gpio0 15 GPIO_ACTIVE_HIGH> /* DRV11 AD10 -> P0.15 */
            , <&gpio0 14 GPIO_ACTIVE_HIGH> /* DRV12 AC9 -> P0.14 */
            , <&gpio1 5  GPIO_ACTIVE_HIGH> /* DRV13 T23 -> P1.05 */
            , <&gpio0 17 GPIO_ACTIVE_HIGH> /* DRV14 AD12 -> P0.17 */
            , <&gpio1 3  GPIO_ACTIVE_HIGH> /* DRV15 V23 -> P1.03 */
            ;
    };

    direct_kscan: kscan_direct {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;
        input-gpios
            = <&gpio1 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>   /* HOTKEY -> P1.08 */
            , <&gpio1 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  /* PWRSWITCH -> P1.11 */
            ;
    };

    gpio_ps2: gpio_ps2 {
        status = "okay";
        compatible = "gpio-ps2";
        scl-gpios = <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; /* TP4CLK -> P1.13 */
        sda-gpios = <&gpio1 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; /* TP4DATA -> P1.10 */
    };

    mouse_ps2: mouse_ps2 {
        status = "okay";
        compatible = "zmk,input-mouse-ps2";
        ps2-device = <&gpio_ps2>;
        rst-gpios = <&gpio1 9 GPIO_ACTIVE_LOW>; /* TP4_RESET -> P1.09 */
    };

    mouse_ps2_input_listener: mouse_ps2_input_listener {
        compatible = "zmk,input-listener-ps2";
        status = "okay";
        device = <&mouse_ps2>;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-voltage-divider";
        io-channels = <&adc 0>; /* A12 -> AIN0 (Channel 0) */
        output-ohms = <100000>;
        full-ohms = <200000>; /* 50% voltage divider */
    };

    pwmleds {
        compatible = "pwm-leds";
        pwm_led_power: pwm_led_power {
            pwms = <&pwm0 0 PWM_MSEC(20) PWM_POLARITY_INVERTED>; /* P0.29 */
        };
    };

    leds {
        compatible = "gpio-leds";
        caps_lock_led: caps_lock_led {
            gpios = <&gpio0 31 GPIO_ACTIVE_LOW>; /* A8 -> P0.31 */
            label = "Caps Lock LED";
        };
        mute_led: mute_led {
            gpios = <&gpio1 15 GPIO_ACTIVE_LOW>; /* A14 -> P1.15 */
            label = "Mute LED";
        };
        mic_mute_led: mic_mute_led {
            gpios = <&gpio1 7 GPIO_ACTIVE_LOW>; /* P23 -> P1.07 */
            label = "Mic Mute LED";
        };
        bt_led: bt_led {
            gpios = <&gpio1 2 GPIO_ACTIVE_LOW>; /* W24 -> P1.02 */
            label = "Bluetooth LED";
        };
        bat_led_r: bat_led_r {
            gpios = <&gpio1 6 GPIO_ACTIVE_LOW>; /* R24 -> P1.06 */
            label = "Battery Red LED";
        };
        bat_led_g: bat_led_g {
            gpios = <&gpio1 4 GPIO_ACTIVE_LOW>; /* U24 -> P1.04 */
            label = "Battery Green LED";
        };
    };

    board_ext_power: ext_power {
        compatible = "zmk,ext-power-generic";
        control-gpios = <&gpio0 12 GPIO_ACTIVE_HIGH>; /* 5V_EN -> P0.12 */
        init-delay-ms = <50>;
    };
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        sd_partition: partition@0 {
            label = "softdevice";
            reg = <0x00000000 0x00026000>;
        };
        code_partition: partition@26000 {
            label = "code_partition";
            reg = <0x00026000 0x000c6000>;
        };
        storage_partition: partition@ec000 {
            label = "storage";
            reg = <0x000ec000 0x00008000>;
        };
        boot_partition: partition@f4000 {
            label = "adafruit_boot";
            reg = <0x000f4000 0x0000c000>;
        };
    };
};

&gpio0 {
    status = "okay";
};

&gpio1 {
    status = "okay";
};

&pinctrl {
    pwm0_default: pwm0_default {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 29)>;
        };
    };

    pwm0_sleep: pwm0_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 29)>;
            low-power-enable;
        };
    };
};

&pwm0 {
    status = "okay";
    pinctrl-0 = <&pwm0_default>;
    pinctrl-1 = <&pwm0_sleep>;
    pinctrl-names = "default", "sleep";
};

&gpiote {
    status = "okay";
}
